-- AUTO STRAFE
-- ============================================================
local AutoStrafeConnection = nil

Toggles.AutoStrafe:OnChanged(function()
    if Toggles.AutoStrafe.Value then
        AutoStrafeConnection = RunService.RenderStepped:Connect(function()
            local hum = GetHumanoid()
            local root = GetRootPart()
            if hum and root then
                if hum.MoveDirection.Magnitude > 0 and hum.FloorMaterial == Enum.Material.Air then
                    local camLook = Camera.CFrame.LookVector
                    local camRight = Camera.CFrame.RightVector
                    local moveDir = hum.MoveDirection
                    local dot = camLook:Dot(moveDir)
                    if math.abs(dot) < 0.5 then
                        local strafeDir = camRight:Dot(moveDir) > 0 and 1 or -1
                        root.Velocity = root.Velocity + camRight * strafeDir * 2
                    end
                end
            end
        end)
    else
        if AutoStrafeConnection then
            AutoStrafeConnection:Disconnect()
            AutoStrafeConnection = nil
        end
    end
end)

