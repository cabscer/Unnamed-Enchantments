-- ============================================================
-- UTILITY FUNCTIONS
-- ============================================================
local function GetCharacter()
    return LocalPlayer.Character
end

local function GetHumanoid()
    local char = GetCharacter()
    if char then
        return char:FindFirstChildOfClass('Humanoid')
    end
    return nil
end

local function GetRootPart()
    local char = GetCharacter()
    if char then
        return char:FindFirstChild('HumanoidRootPart')
    end
    return nil
end

local function IsAlive()
    local hum = GetHumanoid()
    return hum and hum.Health > 0
end

local function GetClosestPlayer(maxDist, teamCheck, wallCheck)
    local closest = nil
    local minDist = maxDist or math.huge
    local localChar = GetCharacter()
    if not localChar then return nil end
    local localRoot = localChar:FindFirstChild('HumanoidRootPart')
    if not localRoot then return nil end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if teamCheck and player.Team == LocalPlayer.Team then continue end

        local char = player.Character
        if not char then continue end
        local root = char:FindFirstChild('HumanoidRootPart')
        if not root then continue end
        local hum = char:FindFirstChildOfClass('Humanoid')
        if not hum or hum.Health <= 0 then continue end

        local dist = (root.Position - localRoot.Position).Magnitude
        if dist < minDist then
            if wallCheck then
                local rayParams = RaycastParams.new()
                rayParams.FilterDescendantsInstances = { localChar }
                rayParams.FilterType = Enum.RaycastFilterType.Blacklist
                local result = Workspace:Raycast(Camera.CFrame.Position, (root.Position - Camera.CFrame.Position).Unit * dist, rayParams)
                if result and result.Instance and not result.Instance:IsDescendantOf(char) then
                    continue
                end
            end
            minDist = dist
            closest = player
        end
    end
    return closest
end

local function GetTargetPart(char)
    local partName = Options.AimbotPart and Options.AimbotPart.Value or 'Head'
    if partName == 'Random' then
        local parts = { 'Head', 'HumanoidRootPart', 'Torso', 'UpperTorso', 'LowerTorso' }
        partName = parts[math.random(1, #parts)]
    end
    return char:FindFirstChild(partName) or char:FindFirstChild('Head') or char:FindFirstChild('HumanoidRootPart')
end

-- ============================================================
-- SPEED HACK - VELOCITY BASED
-- ============================================================
local SpeedConnection = nil
local SpeedBodyVelocity = nil

Toggles.SpeedHack:OnChanged(function()
    if Toggles.SpeedHack.Value then
        Library:Notify('Speed Hack enabled', 2)
        SpeedConnection = RunService.Heartbeat:Connect(function()
            local char = GetCharacter()
            local hum = GetHumanoid()
            local root = GetRootPart()
            if not char or not hum or not root then return end
            if not IsAlive() then return end

            local moveDir = hum.MoveDirection
            if moveDir.Magnitude > 0 then
                if not SpeedBodyVelocity or SpeedBodyVelocity.Parent ~= root then
                    if SpeedBodyVelocity then SpeedBodyVelocity:Destroy() end
                    SpeedBodyVelocity = Instance.new('BodyVelocity')
                    SpeedBodyVelocity.MaxForce = Vector3.new(100000, 0, 100000)
                    SpeedBodyVelocity.Velocity = Vector3.new(0, 0, 0)
                    SpeedBodyVelocity.Parent = root
                end
                local speed = Options.WalkSpeed.Value
                SpeedBodyVelocity.Velocity = Vector3.new(moveDir.X * speed, root.Velocity.Y, moveDir.Z * speed)
            else
                if SpeedBodyVelocity then
                    SpeedBodyVelocity.Velocity = Vector3.new(0, root.Velocity.Y, 0)
                end
            end
        end)
    else
        if SpeedConnection then
            SpeedConnection:Disconnect()
            SpeedConnection = nil
        end
        if SpeedBodyVelocity then
            SpeedBodyVelocity:Destroy()
            SpeedBodyVelocity = nil
        end
        local hum = GetHumanoid()
        if hum then
            hum.WalkSpeed = 16
        end
        Library:Notify('Speed Hack disabled', 2)
    end
end)

