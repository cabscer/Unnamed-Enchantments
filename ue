-- AIMBOT LOGIC
-- ============================================================
local AimbotConnection = nil
local FOV_Circle = nil

local function CreateFOVCircle()
    if FOV_Circle then FOV_Circle:Remove() end
    FOV_Circle = Drawing.new('Circle')
    FOV_Circle.Visible = false
    FOV_Circle.Thickness = 1.5
    FOV_Circle.Color = Color3.new(1, 1, 1)
    FOV_Circle.Transparency = 0.5
    FOV_Circle.Filled = false
    FOV_Circle.NumSides = 64
    return FOV_Circle
end

CreateFOVCircle()

Toggles.Aimbot:OnChanged(function()
    if Toggles.Aimbot.Value then
        Library:Notify('Aimbot enabled', 2)
        AimbotConnection = RunService.RenderStepped:Connect(function()
            if FOV_Circle then
                if Toggles.AimbotShowFOV.Value then
                    FOV_Circle.Visible = true
                    FOV_Circle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                    FOV_Circle.Radius = Options.AimbotFOV.Value
                else
                    FOV_Circle.Visible = false
                end
            end

            local target = GetClosestPlayer(
                Options.AimbotFOV.Value,
                Toggles.AimbotTeamCheck.Value,
                Toggles.AimbotWallCheck.Value
            )
            if target then
                local char = target.Character
                local targetPart = GetTargetPart(char)
                if targetPart then
                    local smoothness = Options.AimbotSmoothness.Value
                    if smoothness > 0 then
                        local targetCF = CFrame.new(Camera.CFrame.Position, targetPart.Position)
                        Camera.CFrame = Camera.CFrame:Lerp(targetCF, smoothness)
                    else
                        Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPart.Position)
                    end
                end
            end
        end)
    else
        if AimbotConnection then
            AimbotConnection:Disconnect()
            AimbotConnection = nil
        end
        if FOV_Circle then
            FOV_Circle.Visible = false
        end
        Library:Notify('Aimbot disabled', 2)
    end
end)

Options.AimbotFOV:OnChanged(function()
    if FOV_Circle then
        FOV_Circle.Radius = Options.AimbotFOV.Value
    end
end)

Toggles.AimbotShowFOV:OnChanged(function()
    if not Toggles.AimbotShowFOV.Value and FOV_Circle then
        FOV_Circle.Visible = false
    end
end)

