local ZixyESP = nil
local esp = nil
local ESP_Loaded = false

-- Try to load ZixyESP from multiple sources
local function LoadZixyESP()
    if ESP_Loaded then return true end

    local urls = {
        'https://raw.githubusercontent.com/zixypy/zixyx/refs/heads/main/zixyesp.txt',
        'https://raw.githubusercontent.com/zixypy/zixyx/main/zixyesp.txt',
        'https://pastebin.com/raw/4rVNKnw0'
    }

    for _, url in ipairs(urls) do
        local success, result = pcall(function()
            return loadstring(game:HttpGet(url))()
        end)
        if success and result then
            ZixyESP = result
            esp = ZixyESP.new()
            ESP_Loaded = true
            return true
        end
    end

    return false
end

